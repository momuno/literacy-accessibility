{
  "name": "Accessing Literacy",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "Rewrites Wikipedia articles to your chosen reading level, powered by a local AI model.",

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://en.wikipedia.org/wiki/*"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "images/books16.png",
      "32":  "images/books32.png",
      "48":  "images/books48.png",
      "128": "images/books128.png"
    },
    "default_title": "Accessing Literacy"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "offscreen",
    "tabs"
  ],

  "host_permissions": [
    "https://en.wikipedia.org/*"
  ]
}
